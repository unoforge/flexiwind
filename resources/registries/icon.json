{
    "$schema": "https://raw.githubusercontent.com/unoforge/flexi-core/main/registry-item.json",
    "version": "1.0.0",
    "name": "icon",
    "type": "registry:component",
    "title": "Icon",
    "description": "A reusable icon component for Laravel Blade/Livewire using Iconify.",
    "files": [
        {
            "path": "resources/views/components/ui/icon.blade.php",
            "type": "registry:component",
            "target": "resources/views/components/ui/icon.blade.php",
            "content": "@props(['name', 'size' => 'sm', 'intent' => 'fg', 'class' => ''])\n\n@php\n    $sizeClasses = [\n        'xs' => 'size-3',\n        'sm' => 'size-4',\n        'md' => 'size-5',\n        'lg' => 'size-6.5',\n        'xl' => 'size-7.5',\n        '2xl' => 'size-9',\n    ];\n\n    $sizeClass = $size ? $sizeClasses[$size] ?? $sizeClasses['md'] : '';\n\n    $intentClasses = [\n        'fg' => 'text-fg',\n        'muted' => 'text-fg-muted',\n        'primary' => 'text-primary',\n        'secondary' => 'text-secondary',\n        'success' => 'text-success',\n        'warning' => 'text-warning',\n        'danger' => 'text-danger',\n    ];\n\n    $intentClass = $intent ? $intentClasses[$intent] ?? '' : '';\n@endphp\n\n<span slot=\"icon\" data-slot=\"icon\" {{ $attributes->class(['flex iconify', $name, $sizeClass, $intentClass, $class]) }}></span>\n"
        }
    ]
}