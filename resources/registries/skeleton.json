{
    "$schema": "https://raw.githubusercontent.com/unoforge/flexi-core/main/registry-item.json",
    "version": "1.0.0",
    "name": "skeleton",
    "type": "registry:component",
    "title": "Skeleton",
    "description": "A reusable skeleton component for Laravel Blade/Livewire.",
    "files": [
        {
            "path": "resources/views/components/ui/skeleton.blade.php",
            "type": "registry:component",
            "target": "resources/views/components/ui/skeleton.blade.php",
            "content": "@props(['radius' => 'circle', 'bgNone' => false])\n\n\n<div\n    {{ $attributes->class([\n        'animate-pulse',\n        'rounded-full' => $radius === 'circle',\n        'rounded-ui' => $radius === 'ui',\n        'bg-bg-muted' => !$bgNone,\n    ]) }}>\n</div>\n"
        }
    ]
}