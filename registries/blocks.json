            "title": "Sidebar Wrapper",
            "description": "A full sidebar wrapper layout.",
            "files": [
                {
                    "path": "resources/views/components/ui/sidebar-wrapper.blade.php",
                    "type": "registry:component",
                    "target": "resources/views/components/ui/sidebar-wrapper.blade.php"
