                {
                    "path": "resources/js/sidebar-plugin.js",
                    "type": "registry:ui",
                    "target": "resources/js/sidebar-plugin.js"
                }
            ],
            "dependencies": {
                "node": [
                    "@flexilla/utilities"
                ]
            },
            "message": [
                "Wrap your sidebar markup with <x-ui.sidebar-wrapper> to get open/close toggle behaviour.",
                "Import resources/js/sidebar-plugin.js in your Vite entry point (e.g. app.js) to activate the sidebar plugin.",
                "Add data-toggle-sidebar to any button that should open/close the sidebar on mobile."
            ]
        },
        {
            "version": "1.0.0",
            "name": "sidebar01",
            "title": "Sidebar 01",
            "description": "A full sidebar layout with grouped navigation.",
            "files": [
                {
                    "path": "resources/views/components/previews/sidebar/01/sidebar.blade.php",
                    "type": "registry:block",
                    "target": "resources/views/components/layouts/sidebar.blade.php",
                    "replace": {
                        "x-previews.sidebar.01.sidebar-item": "x-atoms.sidebar-item",
                        "x-previews.sidebar.01.sidebar-nav-group": "x-atoms.sidebar-nav-group"
                    }
                },
                {
                    "path": "resources/views/components/previews/sidebar/01/sidebar-item.blade.php",
                    "type": "registry:component",
                    "target": "resources/views/components/atoms/sidebar-item.blade.php"
                },
                {
                    "path": "resources/views/components/previews/sidebar/01/sidebar-nav-group.blade.php",
                    "type": "registry:component",
                    "target": "resources/views/components/atoms/sidebar-nav-group.blade.php",
                    "replace":{
                         "x-previews.sidebar.01.sidebar-item": "x-atoms.sidebar-item"
                    }
                },
                {
                    "path": "resources/views/components/previews/sidebar/01/wrapper.blade.php",
                    "type": "registry:block",
                    "target": "resources/views/components/layouts/wrapper.blade.php"
                }
            ],
            "registryDependencies": [
                "button",
                "icon",
                "sidebar-wrapper"
            ],
            "message": [
                "Include <x-layouts.sidebar> at the top level of your page — it renders as a fixed left panel.",
                "Use <x-atoms.sidebar-nav-group> inside the sidebar to group nav links under a labelled section.",
                "Use <x-atoms.sidebar-item> inside each nav group (accepts href, icon, text, isActive).",
                "Place <x-layouts.wrapper> after the sidebar; it offsets by lg:pl-64 and holds your header + content.",
                "Add data-toggle-sidebar to your mobile menu button inside <x-layouts.wrapper> to open the sidebar."
            ]
        },
